@model IEnumerable<MVC_AYAT.Orderdetal>


@{
    ViewBag.Title = "Details";
}

<style>
    #CartItemContainer {
        float: left;
        width: 40%;
        margin-top: 30px;
        margin-left: 486px;
    }

   .CortTitel {
        float: left;
        width: 100%;
        height: 39px;
        font-size: 23px;
        text-align: center;
        background: #b189ff;
        color: #fff;
    }

    .ItemRow {
        float: left;
        width: 100%;
    }

    #itempric {
        float: right;
        font-size: 16px;
        margin-top: 43px;
        font-style: italic;
        color: #1a191c;
    }

    .RemoveRow {
        float: right;
        color: #721cc1;
        margin-top: 15px;
        cursor: pointer;
    }

    #imge {
        float: left;
        width: 100px;
        height: 100px;
        margin-top: 11px;
        margin-left: 12px;
    }

    #spanSizeName {
        float: left;
        margin-top: 46px;
        font-size: 19px;
        margin-left: 9px;
        width: 214px;
        color: #1a191c;
        font-style: oblique;
    }

    .QuantityContenar {
        float: left;
        margin-top: 51px;
    }

    input[disabled] {
        cursor: default;
        color: #383640;
        text-align: center;
    }

    .TotalPrice {
        float: left;
        width: 100%;
        height: 34px;
        font-size: 19px;
        text-align: center;
        background: #b189ff;
        color: #fff;
        margin-top: 10px;
    }

    #Checkout button {
        float: left;
        border: 1px solid #ffff;
        background-color: #ac78ff;
        color: #fff;
        border-radius: 9px;
        width: 156px;
        margin-left: 303px;
        height: 38px;
    }
</style>
<div id="CartItemContainer">

    <span class="CortTitel">@Model.FirstOrDefault().Order.User.Name (@Model.FirstOrDefault().Order.User.Mobilenumber)</span>
    
    @foreach (var item in Model)
     {
         <div class="ItemRow">
             <img id="imge" src="@Url.Content("/Content/img/"+item.ItemSizePric.Item.ImageName+"")" />
             <span id="spanSizeName">@item.ItemSizePric.Item.Name (@item.ItemSizePric.Size.Name)</span>
     
             <div class="QuantityContenar">
                 <input type="number" id="Quantity-@item.OrderdetalsID" min="1" value="@item.Quontity" disabled />
             </div>
             <span id="itempric">@item.Price JOD</span>
         </div>
     }
    <span class="TotalPrice">Total :@Model.Sum(x => x.Price) JOD</span>
    <div id="Checkout"><button onclick="Submit(@(Model.FirstOrDefault().OrderID))" >Submit</button></div>
</div>

<script>
    
    function Submit(OrderID) {
        
            $.ajax({
                url: "/Home/Submit",
                data: { orderID: OrderID },
                success: function () {
                    window.location = "/Home/Orders";
                }
            });

        
    }
</script>